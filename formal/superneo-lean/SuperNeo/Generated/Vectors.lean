import SuperNeo.Field

set_option maxRecDepth 100000

namespace SuperNeo.Generated

structure SuperNeoCase where
  a : Array Nat
  b : Array Nat
  expectedCt : Nat
  expectedDot : Nat
deriving Repr

structure RingMulCase where
  a : Array Nat
  b : Array Nat
  expected : Array Nat
deriving Repr

structure NormCase where
  a : Array Nat
  expectedNorm : Nat
deriving Repr

structure SplitCase where
  input : Array Nat
  base : Nat
  k : Nat
  expectedDigits : Array (Array Nat)
  expectedRecomposed : Array Nat
deriving Repr

structure EqCase where
  x : Array Nat
  y : Array Nat
  expected : Nat
deriving Repr

structure MleCase where
  v : Array Nat
  r : Array Nat
  expectedInner : Nat
  expectedFold : Nat
deriving Repr

structure EmbeddingVecCase where
  input : Array Nat
  expectedBlocks : Array (Array Nat)
deriving Repr

structure EmbeddingMatrixCase where
  input : Array (Array Nat)
  expectedBlocks : Array (Array (Array Nat))
deriving Repr

structure BarLiftVecCase where
  v : Array Nat
  w : Array Nat
  scalar : Nat
  expectedLiftV : Array Nat
  expectedLiftW : Array Nat
  expectedLiftAdd : Array Nat
  expectedLiftScale : Array Nat
deriving Repr

structure BarLiftMatrixCase where
  input : Array (Array Nat)
  expectedLifted : Array (Array Nat)
deriving Repr

structure MatrixTransformCase where
  matrix : Array (Array Nat)
  z : Array Nat
  expectedMz : Array Nat
  expectedCtBarMz : Array Nat
deriving Repr

structure EvalLinkCase where
  matrix : Array (Array Nat)
  z : Array Nat
  r : Array Nat
  expectedY : Array Nat
  expectedCtY : Nat
deriving Repr

structure EvalHomCase where
  matrix : Array (Array Nat)
  z1 : Array Nat
  z2 : Array Nat
  r : Array Nat
  rho1 : Nat
  rho2 : Nat
  expectedY1 : Array Nat
  expectedY2 : Array Nat
  expectedYLin : Array Nat
  expectedYDirect : Array Nat
deriving Repr

structure SamplingCase where
  cset : Array (Array Nat)
  vectors : Array (Array Nat)
  expectedStrong : Bool
  expectedMaxRhoNorm : Nat
  expectedBound : Nat
  expectedEmpirical : Nat
deriving Repr

structure EqLiftCase where
  qVals : Array Nat
  z : Array Nat
  expectedSum : Nat
  isBooleanPoint : Bool
  expectedAtBoolean : Nat
deriving Repr

structure InterpCase where
  xs : Array Nat
  ys : Array Nat
  expectedCoeffs : Array Nat
  evalPoint : Nat
  expectedEvalAt : Nat
deriving Repr

